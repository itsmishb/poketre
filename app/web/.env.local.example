# --- Supabase（従来。未設定時はデモモードで UI 表示）---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Cloud SQL / ローカル Postgres（設定時はサーバー側で ocr_staging を参照・更新）---
# 例: postgresql://poketre:poketre_dev@localhost:5432/poketre
DATABASE_URL=

# --- Vertex AI（Gemini）— 出品紹介文の AI 下書き /api/ai/draft-listing-description ---
# プロジェクト ID（必須）
GOOGLE_CLOUD_PROJECT=
# リージョン（未設定時はコード側デフォルト us-central1。東京は asia-northeast1 等）
VERTEX_LOCATION=
# モデル（任意。未設定時は gemini-2.5-flash）
GEMINI_MODEL=
# ローカル: gcloud auth application-default login または GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
# Vercel 等: サービスアカウント JSON を 1 行で（改行エスケープ済み）— キーに Vertex の利用権限を付与
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- OCR本番化（Webアップロード -> GCS -> Cloud Tasks -> Cloud Run Worker）---
GCS_BUCKET=
CLOUD_TASKS_LOCATION=
CLOUD_TASKS_QUEUE=
WORKER_URL=
# OIDC で Tasks から Worker を叩く場合に指定
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=
# Worker 側と共有する簡易ヘッダー認証（任意だが推奨）
OCR_WORKER_SHARED_SECRET=
